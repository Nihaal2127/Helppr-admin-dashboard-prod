# Copy to .env for faster `npm run start` on this large CRA app.
DISABLE_ESLINT_PLUGIN=true
GENERATE_SOURCEMAP=false
BROWSER=none
# Chat Service VPS — optional override (HTTPS only). Default in code: https://chat.helppr.in
# REACT_APP_CHAT_SERVICE_URL=https://chat.helppr.in

# If you see "Something is already running on port 3000", run: npm run start:clean
